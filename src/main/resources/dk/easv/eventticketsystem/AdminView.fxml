<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.SVGPath?>
<?import javafx.scene.text.Font?>

<BorderPane
        maxHeight="-Infinity" maxWidth="-Infinity"
        minHeight="-Infinity" minWidth="-Infinity"
        prefHeight="656.0" prefWidth="1288.0"
        xmlns="http://javafx.com/javafx/25"
        xmlns:fx="http://javafx.com/fxml/1"
        fx:controller="dk.easv.eventticketsystem.GUI.controller.AdminController">

    <center>
        <VBox BorderPane.alignment="CENTER">

            <!-- TOP BAR -->
            <HBox alignment="CENTER_LEFT" prefHeight="64.0" spacing="10.0">
                <padding><Insets left="24.0" right="24.0" top="20.0" bottom="8.0" /></padding>
                <children>
                    <Label styleClass="title-text" stylesheets="@style.css" text="Admin Dashboard">
                        <font><Font size="20.0" /></font>
                    </Label>
                    <Region HBox.hgrow="ALWAYS" />
                    <Button mnemonicParsing="false" onAction="#handleLogout"
                            stylesheets="@style.css" text="Logout">
                        <styleClass>
                            <String fx:value="logout-button" />
                            <String fx:value="logout-icon" />
                        </styleClass>
                        <graphic>
                            <SVGPath styleClass="logout-icon"
                                     content="M17 7l-1.41 1.41L18.17 11H8v2h10.17l-2.58 2.58L17 17l5-5zM4 5h8V3H4c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h8v-2H4V5z" />
                        </graphic>
                    </Button>
                </children>
            </HBox>

            <Separator />

            <!-- ACTION BAR -->
            <HBox alignment="CENTER_LEFT" prefHeight="60.0" spacing="8.0">
                <padding><Insets left="24.0" right="24.0" top="12.0" bottom="12.0" /></padding>
                <children>

                    <!-- Add User -->
                    <Button mnemonicParsing="false" onAction="#handleAddUser"
                            styleClass="add-user-button" stylesheets="@style.css" text="Add User">
                        <graphic>
                            <SVGPath styleClass="button-icon-white"
                                     content="M15 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm-9-2V7H4v3H1v2h3v3h2v-3h3v-2H6zm9 4c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z" />
                        </graphic>
                    </Button>

                    <!-- Edit User: pencil -->
                    <Button mnemonicParsing="false" onAction="#handleEditUser"
                            styleClass="add-user-button" stylesheets="@style.css" text="Edit User">
                        <graphic>
                            <SVGPath styleClass="button-icon-white"
                                     content="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zM20.71 7.04c.39-.39.39-1.02 0-1.41l-2.34-2.34c-.39-.39-1.02-.39-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z" />
                        </graphic>
                    </Button>

                    <!-- Assign Coordinators: group icon -->
                    <Button mnemonicParsing="false" onAction="#handleAssignCoordinators"
                            styleClass="add-user-button" stylesheets="@style.css" text="Assign Coordinators">
                        <graphic>
                            <SVGPath styleClass="button-icon-white"
                                     content="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z" />
                        </graphic>
                    </Button>

                    <Region HBox.hgrow="ALWAYS" />

                </children>
            </HBox>

            <!-- TWO-TABLE ROW -->
            <HBox spacing="16.0" VBox.vgrow="ALWAYS">
                <padding><Insets left="24.0" right="24.0" bottom="0.0" /></padding>
                <children>

                    <!-- User Management -->
                    <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                        <children>
                            <Label text="User Management" style="-fx-text-fill: -fx-mid-text-color;">
                                <font><Font size="13.0" /></font>
                            </Label>
                            <TableView fx:id="tblAdmin" prefHeight="320.0" maxWidth="Infinity">
                                <columns>
                                    <TableColumn fx:id="colUsername" prefWidth="170.0" text="Username" />
                                    <TableColumn fx:id="colFullName" prefWidth="220.0" text="Full Name" />
                                    <TableColumn fx:id="colRole"     prefWidth="150.0" text="Role" />
                                </columns>
                            </TableView>
                        </children>
                    </VBox>

                    <!-- Event Management -->
                    <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                        <children>
                            <Label text="Event Management" style="-fx-text-fill: -fx-mid-text-color;">
                                <font><Font size="13.0" /></font>
                            </Label>
                            <TableView fx:id="tblEventManagement" prefHeight="320.0" maxWidth="Infinity">
                                <columns>
                                    <TableColumn fx:id="colEventName"            prefWidth="160.0" text="Event Name" />
                                    <TableColumn fx:id="colEventLocation"        prefWidth="160.0" text="Location" />
                                    <TableColumn fx:id="colStartDateAdmin"       prefWidth="110.0" text="Start Date" />
                                    <TableColumn fx:id="colEndDateAdmin"         prefWidth="110.0" text="End Date" />
                                    <TableColumn fx:id="colAssignedCoordinators" prefWidth="200.0" text="Assigned Coordinators" />
                                </columns>
                            </TableView>
                        </children>
                    </VBox>

                </children>
            </HBox>

            <!-- BOTTOM BAR -->
            <HBox alignment="CENTER_LEFT" prefHeight="56.0" spacing="8.0">
                <padding><Insets left="24.0" top="10.0" /></padding>
                <children>

                    <!-- Remove Coordinator: person minus -->
                    <Button fx:id="btnRemoveCoordinatorOrEvent"
                            mnemonicParsing="false" onAction="#handleRemoveCoordinator"
                            styleClass="action-button-remove" stylesheets="@style.css"
                            text="Remove Coordinator">
                        <graphic>
                            <SVGPath style="-fx-fill: #d97706;"
                                     content="M14 14.252V16.3414C13.3744 16.1203 12.7013 16 12 16C8.68629 16 6 18.6863 6 22H4C4 17.5817 7.58172 14 12 14C12.6906 14 13.3608 14.0875 14 14.252ZM12 13C8.685 13 6 10.315 6 7C6 3.685 8.685 1 12 1C15.315 1 18 3.685 18 7C18 10.315 15.315 13 12 13ZM12 11C14.21 11 16 9.21 16 7C16 4.79 14.21 3 12 3C9.79 3 8 4.79 8 7C8 9.21 9.79 11 12 11ZM15 19H23V21H15V19Z" />
                        </graphic>
                    </Button>

                    <!-- Delete Event: trash -->
                    <Button mnemonicParsing="false" onAction="#handleDeleteEvent"
                            styleClass="action-button-remove" stylesheets="@style.css"
                            text="Delete Event">
                        <graphic>
                            <SVGPath style="-fx-fill: #d97706;"
                                     content="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z" />
                        </graphic>
                    </Button>

                </children>
            </HBox>

        </VBox>
    </center>
</BorderPane>
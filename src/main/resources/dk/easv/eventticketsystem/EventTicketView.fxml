<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="560.0" prefWidth="520.0"
            xmlns="http://javafx.com/javafx/24.0.1"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="dk.easv.eventticketsystem.GUI.controller.EventTicketController">
    <top>
        <HBox alignment="BOTTOM_LEFT" prefHeight="55.0">
            <padding><Insets left="20.0" top="15.0"/></padding>
            <children>
                <Label fx:id="lblEventTitle" styleClass="title-text" stylesheets="@style.css" text="Create Ticket">
                    <font><Font size="18.0"/></font>
                </Label>
            </children>
        </HBox>
    </top>
    <center>
        <VBox spacing="12.0">
            <padding><Insets left="20.0" right="20.0"/></padding>
            <children>

                <TextField fx:id="txtCustomerFullName" promptText="Customer Full Name"/>
                <TextField fx:id="txtCustomerMail" promptText="Customer Email"/>

                <Separator/>

                <HBox spacing="10.0" alignment="CENTER_LEFT">
                    <children>
                        <ComboBox fx:id="cbTicketType" prefWidth="250.0" promptText="Select Ticket Type"/>
                        <TextField fx:id="txtAmount" prefWidth="70.0" promptText="Amount"/>
                        <Button text="+ Add" onAction="#handleAddToCart" styleClass="add-user-button" stylesheets="@style.css"/>
                    </children>
                </HBox>

                <Label text="Cart:">
                    <font><Font size="13.0"/></font>
                </Label>
                <TableView fx:id="tblCart" prefHeight="160.0" prefWidth="480.0">
                    <columns>
                        <TableColumn fx:id="colCartType" text="Ticket Type" prefWidth="230.0"/>
                        <TableColumn fx:id="colCartAmount" text="Antal" prefWidth="60.0"/>
                        <TableColumn fx:id="colCartPrice" text="Pris/stk" prefWidth="80.0"/>
                        <TableColumn fx:id="colCartTotal" text="Subtotal" prefWidth="80.0"/>
                        <TableColumn fx:id="colCartRemove" text="" prefWidth="60.0"/>
                    </columns>
                    <placeholder><Label text="No tickets added yet"/></placeholder>
                </TableView>

                <HBox alignment="CENTER_RIGHT">
                    <children>
                        <Label fx:id="lblTotal" styleClass="title-text" stylesheets="@style.css" text="Total: 0,00 kr">
                            <font><Font size="14.0"/></font>
                        </Label>
                    </children>
                </HBox>

                <HBox spacing="10.0" alignment="CENTER_RIGHT">
                    <children>
                        <Button text="Manage Ticket Types" onAction="#handleManageTypes"/>
                    </children>
                </HBox>

            </children>
        </VBox>
    </center>
    <bottom>
        <HBox alignment="CENTER_RIGHT" spacing="10.0" prefHeight="60.0">
            <padding><Insets bottom="15.0" right="20.0"/></padding>
            <children>
                <Button text="Print Ticket" onAction="#handleSavePdf"
                        styleClass="add-user-button" stylesheets="@style.css"/>
            </children>
        </HBox>
    </bottom>
</BorderPane>